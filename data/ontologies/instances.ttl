    evid:hasNotes "Prosidy: Individually tested models did NOT reveal a significant fit for not for self-consistency (r = .10, AdjR2 = 0.04, p= .6, BIC= 7.19).; (r = .10, AdjR2 = 0.04, p= .6, BIC= 7.19)"^^xsd:string ;
