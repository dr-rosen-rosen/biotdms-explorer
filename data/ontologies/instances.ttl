inst:measure_meas_4030 a meas:Measure ;
    rdfs:label "Sliding Window Entropy of Team Communication" ;
    meas:hasDescription "Quantifies temporal fluctuations in the distribution of coded team communication behaviors to identify phase transitions during collaborative problem-solving" ;
    meas:hasInterpretation "Higher entropy = greater disorder/flexibility; peaks indicate phase transitions; lower entropy at transition points predicts better performance" ;
    meas:hasLevelOfAnalysis inst:level_team_level_with_nested_epochs_within_teams ;
    meas:hasName "Sliding Window Entropy of Team Communication" ;
    meas:hasScale "Continuous (entropy values over time; derived peak indicators)" ;
    meas:includesModality inst:modality_verbal_communication_audio_transcript_coded_utterances ;
    meas:measuresConstruct inst:construct_adaptation ;
    meas:usesAnalyticTechnique inst:tech_shannon_entropy_sliding_window_entropy_time_series_analysis_peak_detection_multilevel_modeling .

inst:measure_meas_4039 a meas:Measure ;
