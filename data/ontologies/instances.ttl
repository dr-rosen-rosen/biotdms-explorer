inst:measure_meas_3018 a meas:Measure ;
    rdfs:label "The Empathy Assessment Index" ;
    meas:hasDescription "The Empathy Assessment Index (Gerdes et al., 2011) was adopted as an empathy scale because it contained a reasonably balance between both the cognitive and emotional features of empathy, its psychometrics were good, and its administration time was brief." ;
    meas:hasInterpretation "Higher scores indicate greater empathy" ;
    meas:hasLevelOfAnalysis inst:level_individual_level ;
    meas:hasName "The Empathy Assessment Index" ;
    meas:hasScale "6-point response scale: 1 = never true, 2 = rarely true, 3 = sometimes true, 4 = frequently true, 5 = usually true, 6 = always true." ;
    meas:includesModality inst:modality_self_report ;
    meas:measuresConstruct inst:construct_team_affect ;
    meas:usesAnalyticTechnique inst:tech_simple_aggregation .

inst:measure_meas_3019 a meas:Measure ;
    rdfs:label "Taylor Manifest Anxiety Scale" ;
    meas:hasDescription "The trait anxiety measurement was a variation of the Taylor Manifest Anxiety Scale (Taylor, 1953) that was used in earlier research (Guastello, Boeh et al., 2012, 2013; Guastello, Malon et al., 2014). It consisted of 19 statements such as, “I have nightmares about my job or classes.”" ;
    meas:hasInterpretation "Higher scores indicate higher trait anxiety" ;
    meas:hasLevelOfAnalysis inst:level_individual_level ;
    meas:hasName "Taylor Manifest Anxiety Scale" ;
    meas:hasScale "0 = disagree, 1 = uncertain, 2 = agree; Likert-type summed scale" ;
    meas:includesModality inst:modality_self_report ;
    meas:measuresConstruct inst:construct_team_affect ;
    meas:usesAnalyticTechnique inst:tech_simple_aggregation .

inst:measure_meas_3036 a meas:Measure ;
    rdfs:label "Quadratic Coherence" ;
    meas:hasDescription "coherence is the spectral equivalent to a cross-correlation where values of 0 convey no coordination and a value of 1 conveys absolute coordination between the two time series" ;
    meas:hasInterpretation "higher score, higher coordination" ;
    meas:hasLevelOfAnalysis inst:level_team ;
    meas:hasName "Quadratic Coherence" ;
    meas:hasScale "0-1" ;
    meas:includesModality inst:modality_physiological ;
    meas:measuresConstruct inst:construct_physiological_synchrony .

inst:measure_meas_3037 a meas:Measure ;
    rdfs:label "Factorized Problem Solving Performance" ;
    meas:hasDescription "Problem solving performance was determined by a rescaled com- bination of three variables: (a) the total time taken to restore life sup- port (0–25 min), (b) the total percentage of oxygen restored (0–100%), and (c) a ratio of completed object repairs to the total possible repairs (0–25; only for teams that restored zero oxygen)." ;
    meas:hasInterpretation "Higher score, higher performance" ;
    meas:hasLevelOfAnalysis inst:level_team_level ;
    meas:hasName "Factorized Problem Solving Performance" ;
    meas:hasScale "0-100" ;
    meas:includesModality inst:modality_observed ;
    meas:measuresConstruct inst:construct_task_outcome ;
    meas:usesAnalyticTechnique inst:tech_factorized_version_of_performance,
        inst:tech_rescaled_combination_of_three_variables_see_description .

