    rdfs:label "teamwork" .

inst:measure_5051 a meas:Measure ;
    rdfs:label "Training condition" ;
    meas:hasDescription "Between-team training (control vs coordination coaching vs trust calibration)" ;
    meas:hasLevelOfAnalysis inst:level_team ;
    meas:hasName "Training condition" ;
    meas:includesModality inst:modality_experimental_manipulation ;
    meas:measuresConstruct inst:construct_coordination ;
    meas:usesAnalyticTechnique inst:tech_between_groups_factor .

inst:measure_meas_046 a meas:Measure ;
    rdfs:label "Project Design Performance" ;
    meas:hasDescription """The teamâ€™s success at the end of
the semester was evaluated by their instructor. Because of the dramatic differences between the requirements for the differ-
ent projects, a scientific success metric was created. Each
team had a set of project-specific design requirements they
were asked to meet in the beginning of semester. The degree
to which each requirement was met for each team resulted in
their final success score. This metric went from 0 to 1, with 1
requiring that the team exceeded every single requirement.""",
        "The team’s success at the end of_x000D_ the semester was evaluated by their instructor. Because of the dramatic differences between the requirements for the differ-_x000D_ ent projects, a scientific success metric was created. Each_x000D_ team had a set of project-specific design requirements they_x000D_ were asked to meet in the beginning of semester. The degree_x000D_ to which each requirement was met for each team resulted in_x000D_ their final success score. This metric went from 0 to 1, with 1_x000D_ requiring that the team exceeded every single requirement." ;
    meas:hasInterpretation "Each_x000D_ team had a set of project-specific design requirements they_x000D_ were asked to meet in the beginning of semester. The degree_x000D_ to which each requirement was met for each team resulted in_x000D_ their final success score. This metric went from 0 to 1, with 1_x000D_ requiring that the team exceeded every single requirement." ;
    meas:hasLevelOfAnalysis inst:level_team ;
    meas:hasName "Project Design Performance" ;
    meas:hasScale "0 to 1" ;
    meas:includesModality inst:modality_observation ;
    meas:measuresConstruct inst:construct_task_outcome ;
    meas:usesAnalyticTechnique inst:tech_simple_aggregation_count .

inst:measure_meas_2003 a meas:Measure ;
    rdfs:label "Positivity" ;
    meas:hasDescription "Utterance constructive in intention or attitude, showing optimism and confidence" ;
    meas:hasInterpretation "Positivity in discourse" ;
    meas:hasLevelOfAnalysis inst:level_team ;
    meas:hasName "Positivity" ;
    meas:hasScale "0/1" ;
    meas:includesModality inst:modality_communication_content ;
    meas:measuresConstruct inst:construct_communication,
        inst:construct_team_cohesion ;
    meas:usesAnalyticTechnique inst:tech_language_analysis_human_coding,
        inst:tech_language_anlaysis_human_coding .

inst:measure_meas_3033 a meas:Measure ;
    rdfs:label "Problem Solving Performance" ;
    meas:hasDescription "Problem solving performance was determined by a rescaled com- bination of three variables: (a) the total time taken to restore life sup- port (0–25 min), (b) the total percentage of oxygen restored (0–100%), and (c) a ratio of completed object repairs to the total possible repairs (0–25; only for teams that restored zero oxygen)." ;
    meas:hasInterpretation "Higher score, higher performance" ;
    meas:hasLevelOfAnalysis inst:level_team_level ;
    meas:hasName "Problem Solving Performance" ;
    meas:hasScale "0-100" ;
    meas:includesModality inst:modality_observed ;
    meas:measuresConstruct inst:construct_task_outcome ;
    meas:usesAnalyticTechnique inst:tech_rescaled_combination_of_three_variables_see_description .

inst:measure_meas_3042 a meas:Measure ;
    rdfs:label "Team Performance Outcome" ;
    meas:hasDescription "Team performance outcome was calculated for every mission as the weighted composite of several system parameters, including duration of warning or alarm state, rate of good photographs per minute, fuel and film used, and the number of missed targets. At the beginning of each mission, each team had an initial score of 1,000, and points were deducted based on the final value of each system parameter (N. Cooke et al., 2020)." ;
    meas:hasInterpretation "Higher score, higher performance" ;
    meas:hasLevelOfAnalysis inst:level_team ;
    meas:hasName "Team Performance Outcome" ;
    meas:hasScale "0-1000" ;
    meas:includesModality inst:modality_observed ;
    meas:measuresConstruct inst:construct_task_outcome ;
    meas:usesAnalyticTechnique inst:tech_simple_aggregation .

inst:measure_meas_3043 a meas:Measure ;
    rdfs:label "Team Processing Efficiency" ;
    meas:hasDescription "Team processing efficiency was calculated as the average efficiency score for all targets in a mission. Target processing efficiency (TPE) scores were determined by the time teams spent within a target waypoint’s effective radius to capture a good photo. Higher TPE scores indicated greater efficiency. Each target started with a score of 1,000 points, with points deducted based on the number of seconds spent in the effective radius. An additional 200 points were subtracted if the team failed to capture a photo for that target (N. Cooke et al., 2020)." ;
    meas:hasInterpretation "Higher score, higher team processing efficiency" ;
    meas:hasLevelOfAnalysis inst:level_team ;
    meas:hasName "Team Processing Efficiency" ;
    meas:hasScale "0-1000" ;
    meas:includesModality inst:modality_observed ;
    meas:measuresConstruct inst:construct_task_outcome ;
    meas:usesAnalyticTechnique inst:tech_simple_aggregation .

inst:measure_meas_4037 a meas:Measure ;
    rdfs:label "Task completion time" ;
    meas:hasDescription "Time (seconds) to complete the tracking trajectory" ;
    meas:hasInterpretation "Lower time = higher team efficiency" ;
    meas:hasLevelOfAnalysis inst:level_dyadic_team_level ;
    meas:hasName "Task completion time" ;
    meas:hasScale "Continuous (seconds)" ;
    meas:includesModality inst:modality_behavioral_performance_temporal ;
    meas:measuresConstruct inst:construct_task_outcome ;
    meas:usesAnalyticTechnique inst:tech_direct_measurement_duration .

inst:measure_meas_4038 a meas:Measure ;
    rdfs:label "Team tracking RMS error" ;
    meas:hasDescription "Root mean square deviation from target path during tracking" ;
    meas:hasInterpretation "Lower error = higher team accuracy" ;
    meas:hasLevelOfAnalysis inst:level_dyadic_team_level ;
    meas:hasName "Team tracking RMS error" ;
    meas:hasScale "Continuous (error units)" ;
    meas:includesModality inst:modality_behavioral_performance_accuracy ;
    meas:measuresConstruct inst:construct_task_outcome ;
    meas:usesAnalyticTechnique inst:tech_rms_error_computation_from_trajectory_time_series .

