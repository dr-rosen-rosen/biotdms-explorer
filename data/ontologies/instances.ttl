    evid:hasEffectLevel "team"^^xsd:string ;
    evid:hasEffectSizeValue "0.304"^^xsd:float ;
    evid:hasIndependentVariable inst:measure_meas_3021 ;
    evid:hasNotes "the absolute value of the synchronization coefficient from the nonlinear model was correlated with false alarm rates in the slow condition (r = .304, p < .05); people who were more influenced by their coworkers made more errors in this condition."^^xsd:string ;
    evid:hasSignificanceCategory "Significantly positive"^^xsd:string ;
    evid:usesEffectSizeMetric "Pearson r"^^xsd:string .

