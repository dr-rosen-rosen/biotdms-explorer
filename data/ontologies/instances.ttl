    meas:hasInterpretation "Lower damage = safer/better performance" ;
    meas:hasLevelOfAnalysis inst:level_dyadic_team_level ;
    meas:hasName "Collision damage" ;
    meas:hasScale "Continuous (force units)" ;
    meas:includesModality inst:modality_behavioral_performance_safety_robustness ;
