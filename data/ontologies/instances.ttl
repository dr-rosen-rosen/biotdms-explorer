    meas:hasName "NA, Coordination Breakdown Counts" ;
    meas:includesModality inst:modality_observation ;
    meas:usesAnalyticTechnique inst:tech_observer_counts .

inst:measure_meas_2035 a meas:Measure ;
    rdfs:label "Respiratory Sinus Arrhythmia (RSA)" ;
    meas:hasName "Respiratory Sinus Arrhythmia (RSA)" ;
    meas:includesModality inst:modality_physiological ;
    meas:measuresConstruct inst:construct_physiological_synchrony ;
    meas:usesAnalyticTechnique inst:tech_and_correlation,
        inst:tech_directional_agreement_da,
        inst:tech_examined_physiological_compliance_between_team_members_using_signal_matching_sm,
        inst:tech_instantaneous_derivative_matching_idm .

inst:measure_meas_3014 a meas:Measure ;
    rdfs:label "False Alarm Rates" ;
    meas:hasDescription "An experimenter who was in the room used a timer and followed a script that listed the time of the appearance of targets and non-target screens. When the bell rang, the experimenter recorded a correct hit or a false alarm. Misses were marked, but it was also possible to count the misses after the session. Hit, miss, and false alarm rates, which were generated by pairs, were assigned to each member of the pair for further analysis." ;
    meas:hasInterpretation "Higher false alarm rate is more incorrect responses, poorer performance, lower accuracy. Lower false alamr rate is fewer incorrect responeses and better performance." ;
    meas:hasLevelOfAnalysis inst:level_dyadic_team_level ;
    meas:hasName "False Alarm Rates" ;
    meas:hasScale "Continuous (0 and up)" ;
    meas:includesModality inst:modality_observed ;
    meas:measuresConstruct inst:construct_task_outcome ;
    meas:usesAnalyticTechnique inst:tech_count .

inst:measure_meas_3017 a meas:Measure ;
    rdfs:label "TLX Ratings: temporal demand" ;
    meas:hasDescription "NASA Task Load Index (TLX) ratings of Subjective Workload." ;
    meas:hasInterpretation "Higher TLX scores indicate greater perceived workload." ;
    meas:hasLevelOfAnalysis inst:level_individual_level ;
    meas:hasName "TLX Ratings: temporal demand" ;
    meas:hasScale "Scales were anchored as 1 = “very low” and 21 = “very high.”" ;
    meas:includesModality inst:modality_self_report ;
    meas:measuresConstruct inst:construct_workload ;
    meas:usesAnalyticTechnique inst:tech_simple_aggregation .

inst:measure_meas_3020 a meas:Measure ;
    rdfs:label "Synchronization Weight (linear model)" ;
    meas:hasDescription "The synchronization weight in the linear model quantifies the extent to which one participant’s physiological state (e.g., GSR) is linearly influenced by their partner’s physiological state over time. It reflects the strength of coupling between two individuals assuming a proportional, linear relationship." ;
    meas:hasInterpretation "Higher values is stronger coupling, lower values is weak coupling" ;
    meas:hasLevelOfAnalysis inst:level_individual_level ;
    meas:hasName "Synchronization Weight (linear model)" ;
    meas:hasScale "continuous" ;
    meas:includesModality inst:modality_physiological ;
    meas:measuresConstruct inst:construct_adaptation ;
    meas:usesAnalyticTechnique inst:tech_linear_dynamical_systems_modeling_coupled_differential_equations_linear_model .

inst:measure_meas_3034 a meas:Measure ;
    rdfs:label "Coherence" ;
    meas:hasDescription "coherence is the spectral equivalent to a cross-correlation where values of 0 convey no coordination and a value of 1 conveys absolute coordination between the two time series" ;
    meas:hasInterpretation "higher score, higher coordination" ;
    meas:hasLevelOfAnalysis inst:level_team ;
    meas:hasName "Coherence" ;
    meas:hasScale "0-1" ;
    meas:includesModality inst:modality_physiological ;
    meas:measuresConstruct inst:construct_physiological_synchrony ;
    meas:usesAnalyticTechnique inst:tech_cross_spectral_coherence_analysis .

inst:measure_meas_3035 a meas:Measure ;
    rdfs:label "Relative Phase" ;
    meas:hasDescription "Relative phase indicates whether the differences in the cycles of the oscillations within that frequency are in-phase (0°), anti-phase (180°), or exhibiting a lag (between 0° and 180°)." ;
    meas:hasInterpretation "0 = in phase, 180 = anti-phase, 0-180 = exhibiting a lag" ;
    meas:hasLevelOfAnalysis inst:level_team ;
    meas:hasName "Relative Phase" ;
    meas:hasScale "0-180 (Degrees)" ;
    meas:includesModality inst:modality_physiological ;
    meas:measuresConstruct inst:construct_physiological_synchrony ;
    meas:usesAnalyticTechnique inst:tech_nonlinear_dynamical_systems_phase_analysis .

inst:measure_meas_3038 a meas:Measure ;
    rdfs:label "%DET Linear (Discrete Recurrence)" ;
    meas:hasDescription "A chat log recorded message sent and received times in seconds, the sender and receiver(s) of the message, and the content of the message. To analyze communication sequence, messages were sequenced according to send times to calculate discrete recurrence plots (Webber & Zbilut, 1994). Discrete team communication states taken from the set of mutually exclusive codes identifying which team member is sending the message and which team member(s) receives it are ordered in a sequence containing no timing information and analyzed using a recurrence plot. Percent determinism (%DET) scores were then calculated using Equation 1 from the discrete recurrence plot and the joint recurrence plot for both the sequencing and timing data. %DET ranges from 0 to 100, with higher scores indicating more determinism." ;
    meas:hasLevelOfAnalysis inst:level_team ;
    meas:hasName "%DET Linear (Discrete Recurrence)" ;
    meas:hasScale "0-100" ;
    meas:includesModality inst:modality_communication_flow ;
    meas:measuresConstruct inst:construct_communication ;
    meas:usesAnalyticTechnique inst:tech_det_linear_discrete_recurrence .

inst:measure_meas_3039 a meas:Measure ;
    rdfs:label "%DET Quadratic (Discrete Recurrence)" ;
    meas:hasDescription "A chat log recorded message sent and received times in seconds, the sender and receiver(s) of the message, and the content of the message. To analyze communication sequence, messages were sequenced according to send times to calculate discrete recurrence plots (Webber & Zbilut, 1994). Discrete team communication states taken from the set of mutually exclusive codes identifying which team member is sending the message and which team member(s) receives it are ordered in a sequence containing no timing information and analyzed using a recurrence plot. Percent determinism (%DET) scores were then calculated using Equation 1 from the discrete recurrence plot and the joint recurrence plot for both the sequencing and timing data. %DET ranges from 0 to 100, with higher scores indicating more determinism." ;
    meas:hasLevelOfAnalysis inst:level_team ;
    meas:hasName "%DET Quadratic (Discrete Recurrence)" ;
    meas:hasScale "0-100" ;
    meas:includesModality inst:modality_communication_flow ;
    meas:measuresConstruct inst:construct_communication ;
    meas:usesAnalyticTechnique inst:tech_det_quadratic_discrete_recurrence .

inst:measure_meas_3040 a meas:Measure ;
    rdfs:label "%DET Linear (Joint Recurrence)" ;
    meas:hasDescription "A chat log recorded message sent and received times in seconds, the sender and receiver(s) of the message, and the content of the message. To analyze communication sequence, messages were sequenced according to send times to calculate discrete recurrence plots (Webber & Zbilut, 1994). Discrete team communication states taken from the set of mutually exclusive codes identifying which team member is sending the message and which team member(s) receives it are ordered in a sequence containing no timing information and analyzed using a recurrence plot. Percent determinism (%DET) scores were then calculated using Equation 1 from the discrete recurrence plot and the joint recurrence plot for both the sequencing and timing data. %DET ranges from 0 to 100, with higher scores indicating more determinism." ;
    meas:hasLevelOfAnalysis inst:level_team ;
    meas:hasName "%DET Linear (Joint Recurrence)" ;
    meas:hasScale "0-100" ;
    meas:includesModality inst:modality_communication_flow ;
