inst:measure_meas_4018 a meas:Measure ;
    rdfs:label "Relational Event Model (REM)" ;
    meas:hasDescription "A statistical framework modeling communication as sequences of relational events (â€œwho talks to whom, whenâ€), predicting future patterns from past interactions",
        "A statistical framework modeling communication as sequences of relational events (“who talks to whom, when”), predicting future patterns from past interactions" ;
    meas:hasInterpretation "Positive = pattern encouraged (more likely); Negative = pattern discouraged (less likely)" ;
    meas:hasLevelOfAnalysis inst:level_team ;
    meas:hasName "Relational Event Model (REM)" ;
