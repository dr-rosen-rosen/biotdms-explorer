inst:measure_meas_3023 a meas:Measure ;
    rdfs:label "Empath (linear)" ;
    meas:hasDescription "Empaths would be the individuals who are most responsive to other members in the group (i.e., they were more likely to synchronize to others’ physiological trends).ER team members were classified as drivers and empaths, based on the autocorrelations and transfer influences to and from other players in the GSR time series." ;
    meas:hasLevelOfAnalysis inst:level_individual_level ;
    meas:hasName "Empath (linear)" ;
    meas:includesModality inst:modality_physiological ;
    meas:measuresConstruct inst:construct_coordination ;
    meas:usesAnalyticTechnique inst:tech_synchronization_weight_empath_linear .

inst:measure_meas_3024 a meas:Measure ;
    rdfs:label "Driver (linear)" ;
    meas:hasDescription "Drivers would be the individuals who have the strongest physiological effect on others in the group; (i.e., other players were more likely to synchronize to their physiological behaviors).ER team members were classified as drivers and empaths, based on the autocorrelations and transfer influences to and from other players in the GSR time series." ;
    meas:hasLevelOfAnalysis inst:level_individual_level ;
    meas:hasName "Driver (linear)" ;
    meas:includesModality inst:modality_physiological ;
    meas:measuresConstruct inst:construct_coordination ;
    meas:usesAnalyticTechnique inst:tech_synchronization_weight_driver_linear .

inst:measure_meas_3025 a meas:Measure ;
    rdfs:label "Driver (nonlinear)" ;
    meas:hasDescription "Drivers would be the individuals who have the strongest physiological effect on others in the group; (i.e., other players were more likely to synchronize to their physiological behaviors).ER team members were classified as drivers and empaths, based on the autocorrelations and transfer influences to and from other players in the GSR time series." ;
    meas:hasLevelOfAnalysis inst:level_individual_level ;
    meas:hasName "Driver (nonlinear)" ;
    meas:includesModality inst:modality_physiological ;
    meas:measuresConstruct inst:construct_coordination ;
    meas:usesAnalyticTechnique inst:tech_synchronization_weight_driver_nonlinear .

