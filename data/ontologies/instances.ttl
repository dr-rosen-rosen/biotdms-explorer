    meas:usesAnalyticTechnique inst:tech_summed_collision_force_over_time .

inst:measure_meas_4040 a meas:Measure ;
    rdfs:label "Team coordination (joystick cross-correlation)" ;
    meas:hasDescription "Similarity of team members’ control inputs via cross-correlation at lag 0" ;
    meas:hasInterpretation "Higher positive correlation = greater coordination (not always linked to effectiveness)" ;
    meas:hasLevelOfAnalysis inst:level_dyadic_team_level ;
    meas:hasName "Team coordination (joystick cross-correlation)" ;
    meas:hasScale "Continuous (−1 to 1)" ;
    meas:includesModality inst:modality_behavioral_interaction_motor_coordination ;
    meas:measuresConstruct inst:construct_coordination ;
    meas:usesAnalyticTechnique inst:tech_autoregressive_corrected,
        inst:tech_cross_correlation_time_series,
        inst:tech_lag_0 .

